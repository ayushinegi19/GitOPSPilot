# ── Database (Neon Postgres connection string) ──────────────────────────────
# Get this from the Neon Console -> your project -> Dashboard -> Connection string.
# Use the "Pooled connection" string (recommended, works fine with the pg Pool
# in this app) — it looks like:
DATABASE_URL=postgresql://[user]:[password]@[project-id]-pooler.[region].aws.neon.tech/[dbname]?sslmode=require

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ── GitHub Webhook ───────────────────────────────────────────────────────────
# Any random string. Must match the "Secret" field you set on the GitHub repo's
# Settings -> Webhooks -> Add webhook page.
GITHUB_WEBHOOK_SECRET=change_this_to_a_long_random_string

# ── Health Check / Auto-Rollback (Phase 2) ──────────────────────────────────
# URL the health checker will poll after every successful deploy.
HEALTH_CHECK_URL=http://localhost:4000/health

# How often to poll (seconds)
HEALTH_CHECK_INTERVAL_SECONDS=10

# Sliding window used to evaluate error_rate / latency_spike policies (seconds)
HEALTH_CHECK_WINDOW_SECONDS=180

# Used by the "consecutive_failures" policy
HEALTH_CHECK_FAILURE_THRESHOLD=3

# Which policy decides when to roll back: consecutive_failures | error_rate | latency_spike
ROLLBACK_POLICY=consecutive_failures

# Used by the "error_rate" policy (percentage, 0-100)
ROLLBACK_ERROR_RATE_THRESHOLD=50

# Used by the "latency_spike" policy (milliseconds)
ROLLBACK_LATENCY_THRESHOLD_MS=2000
